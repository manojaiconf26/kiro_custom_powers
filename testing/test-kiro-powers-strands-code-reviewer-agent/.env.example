# =============================================================================
# Code Reviewer Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your chosen provider.

# Provider selection: "ollama", "groq", or "bedrock"
MODEL_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Ollama (local) — default for local development
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# -----------------------------------------------------------------------------
# Groq (cloud, free tier available) — fast inference for local development
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# Amazon Bedrock — for deployed / production environments
# -----------------------------------------------------------------------------
# Uses standard AWS credential chain (env vars, ~/.aws/credentials, IAM role)
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-sonnet-4-20250514-v1:0
